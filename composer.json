{
  "name": "kokspflanze/small-user",
  "description": "Laminas Module for User",
  "type": "library",
  "keywords": [
    "framework",
    "zf",
    "user",
    "auth",
    "acl",
    "laminas"
  ],
  "homepage": "https://github.com/kokspflanze/SmallUser",
  "autoload": {
    "psr-4": {
      "SmallUser\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-0": {
      "SmallUserTest\\": "tests/"
    }
  },
  "extra": {
      "laminas": {
        "config-provider": "SmallUser\\ConfigProvider"
      }
    },
  "require": {
    "php": "^8.2",
    "laminas/laminas-servicemanager": "^3.0",
    "laminas/laminas-stdlib": "^3.0",
    "laminas/laminas-form"  : "^3.21",
    "laminas/laminas-filter": "^2.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^7.5.18",
    "laminas/laminas-db": "^2.9.3"
  }
}
